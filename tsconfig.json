{
	"compilerOptions": {
		"module": "esnext",
		"moduleResolution": "bundler",
		"target": "ES2022",
		"lib": ["ES2022"],
		"resolveJsonModule": true,
		"sourceMap": true,
		"typeRoots": ["./node_modules/@types", "./typings"],
		"strict": true,
		"noImplicitReturns": true,
		"noFallthroughCasesInSwitch": true,
		"noUnusedParameters": true,
		"noPropertyAccessFromIndexSignature": true,
		"types": ["node"],
	},
	"include": ["src", "*.ts"],
}
