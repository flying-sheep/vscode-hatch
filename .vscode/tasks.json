// See https://go.microsoft.com/fwlink/?LinkId=733558
// for the documentation about the tasks.json format
{
	"version": "2.0.0",
	"tasks": [
		{
			"type": "npm",
			"script": "watch",
			"isBackground": true,
			"presentation": {
				"reveal": "never",
			},
			"group": {
				"kind": "build",
				"isDefault": true,
			},
			"problemMatcher": {
				"background": {
					"activeOnStart": true,
					"beginsPattern": "Found.*changed, rebuilding",
					"endsPattern": "✔ Rebuilt.*",
				},
				"pattern": [
					{
						"regexp": "^(\\[[^\\\\n]+)\\\\n[^\\[]+\\[\\\\s*([^:]+):(\\\\d+:\\\\d+).*",
						"message": 1,
						"file": 2,
						"location": 3,
					},
				],
			},
		},
	],
}
